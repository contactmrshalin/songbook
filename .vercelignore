# Vercel Build Configuration
# Note: Root directory is set to "platform" in Vercel dashboard
# Only ignore root-level directories; platform/* is the actual deployment root

# Mobile app (uses React Native, different deps)
mobile-app/

# Root-level data and scripts (not needed for web deployment)
# Platform has its own scripts directory that MUST be included
data/
tests/
misc/
legacy-site-hugo/

# Python venvs and caches
.venv/
__pycache__/
*.pyc

# Git files
.git/
.gitignore

# Lock files (only need one per workspace)
package-lock.json

# Editor and system files
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Build outputs
build/
dist/
out/
.next/
