# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# song data copied by deploy.sh for Vercel CLI
.songdata/

# images — tracked in Git so Vercel can serve them
# (copied locally by scripts/setup-dev.sh from data/images/)
# public/song-images/

# generated song bundle — tracked in Git so Vercel can build
# (rebuilt locally by scripts/prebuild.mjs or setup-dev.sh)
# src/generated/

# typescript
*.tsbuildinfo
next-env.d.ts
