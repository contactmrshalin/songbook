    "R": { "step": "D", "alter": 0 },
    "G": { "step": "E", "alter": 0 },
    "m": { "step": "F", "alter": 0 },
    "M": { "step": "F", "alter": 1 },
    "P": { "step": "G", "alter": 0 },
    "D": { "step": "A", "alter": 0 },
    "N": { "step": "B", "alter": 0 },

    "r": { "step": "D", "alter": -1 },
    "g": { "step": "E", "alter": -1 },
    "d": { "step": "A", "alter": -1 },
    "n": { "step": "B", "alter": -1 }
