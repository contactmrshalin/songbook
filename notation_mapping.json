{
  "version": 1,
  "description": "Indian sargam ↔ token ↔ Western mapping used by the Songbook Pipeline. Edit this file to update mappings going forward.",
  "reference_legend": {
    "western_solfege_to_sargam_token": {
      "DO": "S",
